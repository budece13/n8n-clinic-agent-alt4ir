    {
      "id": "get-session",
      "name": "HTTP - Obtener Sesion",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        600,
        200
      ],
      "parameters": {
        "url": "={{ $env.DJANGO_API_URL }}/api/agent/sessions/",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "phone",
              "value": "={{ $json.phone }}"
            }
          ]
        },
        "options": {}
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "4582aNhH2U92BzV4",
          "name": "Django Auth"
        }
      },
      "continueOnFail": true
    },
    {
      "id": "proc-session",
      "name": "Procesar - Sesion Obtenida",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        200
      ],
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst results = raw.results || (Array.isArray(raw) ? raw : []);\nconst session = results.length > 0 ? results[0] : null;\n\nreturn [{ json: {\n  exists: !!session,\n  session_id: session ? session.id : null,\n  phone: session ? session.phone : $('Trigger - Entrada Sub-workflow').first().json.phone,\n  session_data: session ? session.session_data : {},\n  last_interaction: session ? session.updated_at : null\n}}];"
      }
    },
    {
      "id": "prep-save",
      "name": "Preparar - Datos Sesion",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        400
      ],
      "parameters": {
        "jsCode": "const input = $('Trigger - Entrada Sub-workflow').first().json;\nreturn [{ json: {\n  phone: input.phone,\n  clinic_id: input.clinic_id,\n  session_data: input.session_data || {},\n  session_id: input.session_id || null\n}}];"
      }
    },
    {
      "id": "save-check",
      "name": "¿Sesion Existe para Update?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        900,
        400
      ],
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "operator": {
                "type": "string",
                "operation": "exists",
                "singleValue": true
              },
              "leftValue": "={{ $json.session_id }}"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "update-session",
      "name": "HTTP - Actualizar Sesion",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1200,
        300
      ],
      "parameters": {
        "method": "PATCH",
        "url": "={{ $env.DJANGO_API_URL }}/api/agent/sessions/{{ $json.session_id }}/",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"session_data\": {{ JSON.stringify($json.session_data) }}\n}",
        "options": {}
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "4582aNhH2U92BzV4",
          "name": "Django Auth"
        }
      },
      "continueOnFail": true
    },
    {
      "id": "create-session",
      "name": "HTTP - Crear Sesion",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1200,
        500
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.DJANGO_API_URL }}/api/agent/sessions/",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"clinic\": {{ $json.clinic_id || 1 }},\n  \"phone\": \"{{ $json.phone }}\",\n  \"session_data\": {{ JSON.stringify($json.session_data) }}\n}",
        "options": {}
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "4582aNhH2U92BzV4",
          "name": "Django Auth"
        }
      },
