      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1500,
        400
      ],
      "parameters": {
        "jsCode": "const result = $input.first().json;\nreturn [{ json: { success: !!result.id, session_id: result.id || null, message: result.id ? 'Sesion guardada' : 'Error guardando sesion' }}];"
      }
    },
