    {
      "id": "proc-ctx",
      "name": "Procesar - Contexto Cita",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        850
      ],
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst citas = raw.results || (Array.isArray(raw) ? raw : []);\n\nreturn [{ json: {\n  has_appointment_context: citas.length > 0,\n  upcoming_appointments: citas.length,\n  next_appointment: citas.length > 0 ? {\n    id: citas[0].id,\n    scheduled_at: citas[0].scheduled_at,\n    status: citas[0].status,\n    service: citas[0].service\n  } : null\n}}];"
      }
    },
