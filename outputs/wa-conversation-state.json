      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        1050
      ],
      "parameters": {
        "jsCode": "return [{ json: { success: false, message: 'Accion no reconocida: ' + ($('Trigger - Entrada Sub-workflow').first().json.action || 'null') }}];"
