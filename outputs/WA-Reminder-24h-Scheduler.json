        "operation": "executeQuery",
        "query": "UPDATE scheduler_runs SET appointments_processed = (SELECT COUNT(*) FROM appointments WHERE reminder_24h_sent = true AND reminder_24h_sent_at > NOW() - INTERVAL '10 minutes'), appointments_succeeded = (SELECT COUNT(*) FROM appointments WHERE reminder_24h_sent = true AND reminder_24h_sent_at > NOW() - INTERVAL '10 minutes'), appointments_failed = (SELECT COUNT(*) FROM reminder_errors WHERE reminder_type = '24h' AND created_at > NOW() - INTERVAL '10 minutes'), completed_at = NOW() WHERE id = $1::uuid;",
        "options": {
