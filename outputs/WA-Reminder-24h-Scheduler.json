    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const appt = $json;\nconst dt = new Date(appt.datetime);\nconst tz = appt.timezone || 'Europe/Madrid';\nconst fecha = dt.toLocaleDateString('es-ES', {\n  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', timeZone: tz\n});\nconst hora = dt.toLocaleTimeString('es-ES', {\n  hour: '2-digit', minute: '2-digit', timeZone: tz\n});\nconst nombre = appt.patient_name ? `Hola ${appt.patient_name}` : 'Hola';\n\nconst message_text = `${nombre}\\n\\nTe recordamos que tienes una cita en *${appt.clinic_name}* manana:\\n\\n${fecha}\\n${hora}\\nServicio: ${appt.service}\\n\\nConfirmas tu asistencia?\\nResponde *SI* para confirmar\\nResponde *NO* para cancelar\\nResponde *CAMBIAR* si necesitas otra fecha\\n\\nSi tienes alguna duda, escribenos aqui mismo.`;\n\nreturn { json: { ...appt, message_text } };"
      },
      "id": "format-message",
      "name": "Formatear Mensaje WA",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1344,
        256
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v18.0/{{ $json.whatsapp_phone_number_id }}/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{ $json.patient_phone }}\",\n  \"type\": \"text\",\n  \"text\": { \"body\": {{ JSON.stringify($json.message_text) }} }\n}",
        "options": {
          "timeout": 10000
        }
      },
      "id": "send-wa",
      "name": "Enviar Recordatorio WA",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1600,
        256
      ],
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 3000,
      "credentials": {
        "httpHeaderAuth": {
          "id": "WA_CREDENTIAL_ID",
          "name": "WhatsApp Cloud API"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
