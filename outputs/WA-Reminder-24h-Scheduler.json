    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  a.id as appointment_id,\n  a.patient_phone,\n  a.patient_name,\n  a.service,\n  a.datetime,\n  a.clinic_id,\n  a.external_id,\n  c.name as clinic_name,\n  c.timezone,\n  c.whatsapp_phone_number_id\nFROM appointments a\nJOIN clinics c ON a.clinic_id = c.clinic_id\nWHERE \n  a.status IN ('scheduled', 'confirmed')\n  AND a.reminder_24h_sent = false\n  AND a.datetime >= NOW() + INTERVAL '23 hours'\n  AND a.datetime <= NOW() + INTERVAL '25 hours'\nORDER BY a.datetime ASC\nLIMIT 100;",
        "options": {}
      },
      "id": "fetch-appointments",
      "name": "Buscar Citas 24h",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        304,
        400
      ],
      "credentials": {
        "postgres": {
          "id": "POSTGRES_CREDENTIAL_ID",
          "name": "Postgres Clinica"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
