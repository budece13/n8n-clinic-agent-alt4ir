    {
      "parameters": {
        "options": {}
      },
      "id": "split-batches",
      "name": "Procesar Uno a Uno",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        1088,
        256
      ]
