    {
      "id": "b-preparar-datos-cita",
      "name": "B - Preparar Datos Cita",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        300
      ],
      "parameters": {
        "jsCode": "const trigger = $('Trigger - Execute Workflow').first().json;\nconst patientsRaw = $input.first().json;\nconst patients = patientsRaw.results || (Array.isArray(patientsRaw) ? patientsRaw : []);\n\nif (!patients.length) {\n  throw new Error('Paciente no encontrado para phone: ' + trigger.phone);\n}\n\nconst patient = patients[0];\nconst date = trigger.preferred_date || '';\nconst time = trigger.preferred_time || '09:00';\nconst scheduledAt = date ? `${date}T${time}:00` : '';\n\n// Calcular end_at (1 hora por defecto)\nlet endAt = '';\nif (scheduledAt) {\n  const start = new Date(scheduledAt);\n  start.setHours(start.getHours() + 1);\n  endAt = start.toISOString().slice(0, 19);\n}\n\nreturn [{ json: {\n  patient_id: patient.id,\n  clinic_id: trigger.clinic_id,\n  service: trigger.service || '',\n  scheduled_at: scheduledAt,\n  end_at: endAt,\n  phone: trigger.phone\n}}];"
      }
    },
