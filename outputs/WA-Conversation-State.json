      "maxTries": 3,
      "waitBetweenTries": 3000,
      "credentials": {
        "postgres": {
          "id": "POSTGRES_CREDENTIAL_ID",
          "name": "PostgreSQL Clinica"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { success: true, action: 'save_session' } }];"
      },
      "id": "code-save-resp",
      "name": "Respuesta - Sesion Guardada",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1088,
