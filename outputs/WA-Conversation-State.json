    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT session_data->>'appointment_in_progress' as appointment_draft\nFROM conversation_sessions\nWHERE phone = $1 AND updated_at > NOW() - INTERVAL '30 minutes';",
        "options": {
          "queryReplacement": "={{ $('Trigger - Entrada Sub-workflow').item.json.phone }}"
        }
      },
      "id": "pg-appt-context",
      "name": "PG - Obtener Contexto Cita",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        560,
        1104
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 3000,
      "credentials": {
        "postgres": {
          "id": "POSTGRES_CREDENTIAL_ID",
          "name": "PostgreSQL Clinica"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "try {\n  const items = $input.all();\n\n  if (!items || items.length === 0 || !items[0].json.appointment_draft) {\n    return [{ json: { action: 'get_appointment_context', has_draft: false, appointment_draft: null } }];\n  }\n\n  let draft = items[0].json.appointment_draft;\n  if (typeof draft === 'string') {\n    try { draft = JSON.parse(draft); } catch(e) { /* keep as string */ }\n  }\n\n  return [{ json: { action: 'get_appointment_context', has_draft: true, appointment_draft: draft } }];\n} catch (error) {\n  return [{ json: { action: 'get_appointment_context', has_draft: false, appointment_draft: null, error: error.message } }];\n}"
      },
