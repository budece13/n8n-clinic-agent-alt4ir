        "query": "UPDATE appointments \nSET reminder_responded = true, updated_at = NOW()\nWHERE id = $1\nRETURNING id;",
        "options": {
          "queryReplacement": "={{ $('Trigger - Entrada Sub-workflow').item.json.appointment_id }}"
        }
      },
      "id": "pg-mark-reminder",
      "name": "PG - Marcar Recordatorio Respondido",
      "type": "n8n-nodes-base.postgres",
