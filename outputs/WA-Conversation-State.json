    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  a.id,\n  a.patient_phone,\n  a.patient_name,\n  a.service,\n  a.datetime,\n  a.clinic_id,\n  c.name as clinic_name,\n  c.timezone\nFROM appointments a\nJOIN clinics c ON a.clinic_id = c.clinic_id\nWHERE \n  a.status = 'scheduled'\n  AND a.reminder_24h_sent = false\n  AND a.datetime BETWEEN NOW() + INTERVAL '23 hours' \n                     AND NOW() + INTERVAL '25 hours'\nORDER BY a.datetime ASC;",
        "options": {}
      },
      "id": "pg-reminders-24h",
      "name": "PG - Recordatorios Pendientes 24h",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        560,
        512
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 3000,
      "credentials": {
        "postgres": {
          "id": "POSTGRES_CREDENTIAL_ID",
          "name": "PostgreSQL Clinica"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "try {\n  const items = $input.all();\n  const reminders = items.map(item => item.json);\n  // Filtrar filas vacias (cuando la query no devuelve resultados, n8n envia un item vacio)\n  const validReminders = reminders.filter(r => r.id);\n  return [{ json: { action: 'get_pending_reminders_24h', count: validReminders.length, reminders: validReminders } }];\n} catch (error) {\n  return [{ json: { action: 'get_pending_reminders_24h', count: 0, reminders: [], error: error.message } }];\n}"
      },
      "id": "code-reminders-24h-resp",
      "name": "Respuesta - Recordatorios 24h",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        512
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  a.id,\n  a.patient_phone,\n  a.patient_name,\n  a.service,\n  a.datetime,\n  a.clinic_id,\n  c.name as clinic_name,\n  c.timezone\nFROM appointments a\nJOIN clinics c ON a.clinic_id = c.clinic_id\nWHERE \n  a.status IN ('scheduled', 'confirmed')\n  AND a.reminder_24h_sent = true\n  AND a.reminder_responded = false\n  AND a.reminder_3h_sent = false\n  AND a.datetime BETWEEN NOW() + INTERVAL '2 hours 30 minutes' \n                     AND NOW() + INTERVAL '3 hours 30 minutes'\nORDER BY a.datetime ASC;",
        "options": {}
      },
