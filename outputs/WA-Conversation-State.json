    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  cs.session_data,\n  cs.last_interaction,\n  cs.appointment_context,\n  cs.updated_at,\n  a.id as active_appointment_id,\n  a.service,\n  a.datetime as appointment_datetime,\n  a.status,\n  a.reminder_24h_sent,\n  a.reminder_responded\nFROM conversation_sessions cs\nLEFT JOIN appointments a ON (\n  a.patient_phone = cs.phone \n  AND a.datetime > NOW() \n  AND a.status NOT IN ('cancelled')\n)\nWHERE cs.phone = $1\nORDER BY a.datetime ASC\nLIMIT 1;",
        "options": {
          "queryReplacement": "={{ $('Trigger - Entrada Sub-workflow').item.json.phone }}"
        }
      },
      "id": "pg-get-session",
      "name": "PG - Obtener Sesion",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        560,
        -96
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 3000,
      "credentials": {
        "postgres": {
          "id": "POSTGRES_CREDENTIAL_ID",
          "name": "PostgreSQL Clinica"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "try {\n  const items = $input.all();\n\n  if (!items || items.length === 0 || !items[0].json.session_data) {\n    return [{ json: { session_data: {}, is_new_user: true, appointment_context: null, active_appointment: null } }];\n  }\n\n  const row = items[0].json;\n\n  let sessionData = row.session_data;\n  if (typeof sessionData === 'string') {\n    try { sessionData = JSON.parse(sessionData); } catch(e) { sessionData = {}; }\n  }\n\n  let appointmentContext = row.appointment_context;\n  if (typeof appointmentContext === 'string') {\n    try { appointmentContext = JSON.parse(appointmentContext); } catch(e) { appointmentContext = null; }\n  }\n\n  const result = {\n    session_data: sessionData,\n    is_new_user: false,\n    last_interaction: row.last_interaction,\n    updated_at: row.updated_at,\n    appointment_context: appointmentContext,\n    active_appointment: row.active_appointment_id ? {\n      id: row.active_appointment_id,\n      service: row.service,\n      datetime: row.appointment_datetime,\n      status: row.status,\n      reminder_24h_sent: row.reminder_24h_sent,\n      reminder_responded: row.reminder_responded\n    } : null\n  };\n\n  return [{ json: result }];\n} catch (error) {\n  return [{ json: { success: false, error: 'get_session_processing_error', message: error.message, session_data: {}, is_new_user: true } }];\n}"
      },
      "id": "code-get-session",
      "name": "Procesar - Sesion Obtenida",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        -96
      ]
    },
    {
      "parameters": {
        "jsCode": "try {\n  const input = $('Trigger - Entrada Sub-workflow').item.json;\n\n  let sessionData = input.session_data || {};\n\n  // Truncar historial de mensajes a los ultimos 10\n  if (sessionData.message_history && Array.isArray(sessionData.message_history)) {\n    sessionData.message_history = sessionData.message_history.slice(-10);\n  }\n\n  // Anadir timestamp de actualizacion\n  sessionData._last_updated = new Date().toISOString();\n\n  return [{\n    json: {\n      phone: input.phone,\n      clinic_id: input.clinic_id || null,\n      session_data_json: JSON.stringify(sessionData)\n    }\n  }];\n} catch (error) {\n  return [{ json: { success: false, error: 'save_session_prep_error', message: error.message } }];\n}"
      },
      "id": "code-prep-save",
      "name": "Preparar - Datos Sesion",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        112
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO conversation_sessions (phone, clinic_id, session_data, last_interaction, updated_at)\nVALUES ($1, $2, $3::jsonb, NOW(), NOW())\nON CONFLICT (phone) DO UPDATE SET\n  session_data = EXCLUDED.session_data,\n  last_interaction = NOW(),\n  updated_at = NOW();",
        "options": {
          "queryReplacement": "={{ $json.phone }}, {{ $json.clinic_id }}, {{ $json.session_data_json }}"
        }
      },
      "id": "pg-save-session",
      "name": "PG - Guardar Sesion",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        832,
        112
      ],
