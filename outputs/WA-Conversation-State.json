    {
      "parameters": {
        "jsCode": "try {\n  const input = $('Trigger - Entrada Sub-workflow').item.json;\n  return [{ json: { success: true, action: 'mark_reminder_responded', appointment_id: input.appointment_id } }];\n} catch (error) {\n  return [{ json: { success: false, error: 'mark_reminder_error', message: error.message } }];\n}"
      },
      "id": "code-mark-resp",
      "name": "Respuesta - Recordatorio Marcado",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
