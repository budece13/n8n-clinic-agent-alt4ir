      ],
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "combinator": "or",
          "conditions": [
            {
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              },
              "leftValue": "={{ $json.has_kb }}"
            },
            {
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              },
              "leftValue": "={{ $json.has_services }}"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "generar-respuesta",
      "name": "Generar Respuesta con Contexto",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [
        1300,
        300
      ],
      "parameters": {
        "promptType": "define",
        "text": "=Usando SOLO la información del contexto, responde la pregunta del paciente de forma concisa y profesional en español. No inventes información. Si no encuentras la respuesta en el contexto, di que no tienes esa información y sugiere llamar a la clínica.\n\nCONTEXTO:\n{{ $json.context }}\n\nPREGUNTA: {{ $json.question }}\n\nRESPUESTA:"
      }
    },
    {
      "id": "openai-gen",
      "name": "OpenAI - Generador",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.3,
      "position": [
        1300,
