        }
      }
    },
    {
      "id": "resp-defecto",
      "name": "Respuesta por Defecto",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        550
      ],
      "parameters": {
        "jsCode": "const trigger = $('Trigger - Execute Workflow').first().json;\nreturn [{ json: {\n  response: 'No dispongo de esa información en este momento. Te recomiendo llamar directamente a la clínica para que puedan ayudarte.',\n  question: trigger.question,\n  source: 'default'\n}}];"
      }
    },
    {
      "id": "resp-final",
      "name": "Devolver Respuesta",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1600,
        300
      ],
      "parameters": {
        "jsCode": "const llmOutput = $input.first().json;\nreturn [{ json: {\n  response: llmOutput.text || llmOutput.output || llmOutput.response || 'No pude generar una respuesta.',\n  source: 'knowledge_base'\n}}];"
      }
    },
