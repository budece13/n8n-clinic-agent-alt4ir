    {
      "parameters": {
        "jsCode": "const normalized = $('Normalizar Mensaje').first().json;\nconst session = $('Cargar Sesion').first().json;\nconst reminder = $('Verificar Reminder Pendiente').first().json;\n\nreturn [{ json: {\n  chatInput: normalized.message,\n  phone: normalized.phone,\n  clinic_id: normalized.clinic_id,\n  phone_number_id: normalized.phone_number_id,\n  contact_name: normalized.contact_name,\n  session_data: JSON.stringify(session.session_data || {}),\n  is_reminder_response: !!(reminder && reminder.id),\n  pending_appointment_id: (reminder && reminder.id) ? reminder.id : '',\n  pending_appointment_service: (reminder && reminder.service) ? reminder.service : '',\n  pending_appointment_datetime: (reminder && reminder.datetime) ? String(reminder.datetime) : ''\n}}];"
      },
