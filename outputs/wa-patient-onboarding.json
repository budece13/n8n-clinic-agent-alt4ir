  "nodes": [
    {
      "id": "trigger-nuevo-paciente",
      "name": "Trigger - Nuevo Paciente",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        300
      ],
      "parameters": {
        "inputSource": "passthrough"
      }
    },
    {
      "id": "crear-paciente-django",
      "name": "Crear Paciente en Django",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        300,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.DJANGO_API_URL }}/api/patients/",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Api-Key {{ $env.N8N_DJANGO_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"clinic\": {{ $json.clinic_id }},\n  \"first_name\": \"{{ $json.contact_name || 'Nuevo Paciente' }}\",\n  \"phone\": \"{{ $json.phone }}\"\n}",
        "options": {}
      },
      "continueOnFail": true
    },
    {
      "id": "crear-sesion-conversacional",
      "name": "Crear Sesión Conversacional",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        600,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.DJANGO_API_URL }}/api/agent/sessions/",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Api-Key {{ $env.N8N_DJANGO_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"clinic\": {{ $('Trigger - Nuevo Paciente').first().json.clinic_id }},\n  \"phone\": \"{{ $('Trigger - Nuevo Paciente').first().json.phone }}\"\n}",
        "options": {}
      },
      "continueOnFail": true
    },
    {
      "id": "preparar-mensaje-bienvenida",
      "name": "Preparar Mensaje Bienvenida",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        300
      ],
      "parameters": {
        "jsCode": "const trigger = $('Trigger - Nuevo Paciente').first().json;\nconst patient = $('Crear Paciente en Django').first().json;\n\nreturn [{ json: {\n  response: '¡Hola! Bienvenido/a a nuestra clínica. Soy tu asistente virtual y estoy aquí para ayudarte. Puedo informarte sobre nuestros servicios, agendar una cita o resolver tus dudas. ¿En qué puedo ayudarte?',\n  patient_id: patient.id || null,\n  phone: trigger.phone,\n  clinic_id: trigger.clinic_id,\n  is_new_patient: true\n}}];"
      }
    },
    {
      "id": "error-trigger-global",
      "name": "Error Trigger Global",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [
        0,
        600
      ],
      "parameters": {}
    },
    {
      "id": "log-error-temporal",
      "name": "Log Error Temporal",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        300,
        600
      ],
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "assign-workflow",
