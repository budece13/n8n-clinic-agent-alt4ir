        "jsCode": "const trigger = $('Trigger - Nuevo Paciente').first().json;\nconst patient = $('Crear Paciente en Django').first().json;\n\nreturn [{ json: {\n  response: '\u00a1Hola! Bienvenido/a a nuestra cl\u00ednica. Soy tu asistente virtual y estoy aqu\u00ed para ayudarte. Puedo informarte sobre nuestros servicios, agendar una cita o resolver tus dudas. \u00bfEn qu\u00e9 puedo ayudarte?',\n  patient_id: patient.id || null,\n  phone: trigger.phone,\n  clinic_id: trigger.clinic_id,\n  is_new_patient: true\n}}];"
