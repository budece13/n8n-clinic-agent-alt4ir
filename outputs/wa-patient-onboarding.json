      }
    },
    {
      "id": "nota-descripcion",
      "name": "Nota - Descripción Workflow",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -280,
        -60
      ],
      "parameters": {
        "content": "## WA-Patient-Onboarding\n\nSub-workflow para onboarding de pacientes nuevos.\nSe ejecuta cuando el Orchestrator detecta un teléfono no registrado.\n\n### Endpoints usados\n- POST /api/patients/ — Crear paciente\n- POST /api/agent/sessions/ — Crear sesión\n\n### Endpoints pendientes\n- POST /api/agent/errors/ — Log de errores (ReadOnly en Django)\n\n### Autenticación\nApi-Key via $env.N8N_DJANGO_API_KEY",
        "height": 380,
        "width": 480
      }
    },
    {
      "id": "nota-endpoint-pendiente",
      "name": "Nota - Endpoint Errores Pendiente",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -280,
        540
      ],
      "parameters": {
        "content": "⚠️ ENDPOINT PENDIENTE: Este workflow loguea errores temporalmente con Set node.\nRequiere implementar POST /api/agent/errors/ (escritura) en clinic-app (Django) antes de poder persistir errores en BD.\nVer CLAUDE.md sección 5.",
        "height": 160,
        "width": 480
      }
    }
  ],
