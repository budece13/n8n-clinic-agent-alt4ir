        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const pnid = $('Trigger - Execute Workflow').first().json.phone_number_id;\nconst item = $input.first();\n\nif (item.error) {\n  throw new Error('Error al contactar Django para phone_number_id: ' + pnid);\n}\n\nconst data = item.json;\n\nif (data.detail || data.error) {\n  throw new Error('Error de Django para phone_number_id: ' + pnid + '. Detalle: ' + JSON.stringify(data.detail || data.error));\n}\n\nconst required = ['clinic_id', 'agent_api_key', 'whatsapp_phone_number_id', 'whatsapp_token'];\nconst missing = required.filter(function(f) { return !data[f]; });\n\nif (missing.length > 0) {\n  throw new Error('Config incompleta para phone_number_id: ' + pnid + '. Campos faltantes: ' + missing.join(', '));\n}\n\nreturn [{ json: data }];"
      },
      "id": "validar-config",
      "name": "Validar Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        608,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst result = Object.assign({}, data, {\n  django_auth_header: 'Api-Key ' + data.agent_api_key,\n  whatsapp_api_url: $env.WHATSAPP_API_URL || ''\n});\nreturn [{ json: result }];"
      },
