    {
      "parameters": {
        "jsCode": "const triggerJson = $input.first().json;\nconst chatInput = triggerJson.chatInput ?? '';\n\nif (!chatInput) {\n  throw new Error('chatInput vacío. Raw data: ' + JSON.stringify(triggerJson));\n}\n\nreturn [{ json: {\n  phone: '+34644520621',\n  message: chatInput,\n  message_id: 'chat-' + Date.now(),\n  timestamp: String(Math.floor(Date.now() / 1000)),\n  message_type: 'text',\n  is_text: true,\n  contact_name: 'Usuario Chat',\n  phone_number_id: 'test',\n  clinic_id: 'default'\n}}];"
      },
