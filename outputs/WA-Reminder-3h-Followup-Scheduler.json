    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  a.id as appointment_id,\n  a.patient_phone,\n  a.patient_name,\n  a.service,\n  a.datetime,\n  a.clinic_id,\n  a.reminder_24h_sent_at,\n  c.name as clinic_name,\n  c.timezone,\n  c.whatsapp_phone_number_id\nFROM appointments a\nJOIN clinics c ON a.clinic_id = c.clinic_id\nWHERE \n  a.status IN ('scheduled', 'confirmed')\n  AND a.reminder_24h_sent = true\n  AND a.reminder_responded = false\n  AND a.reminder_3h_sent = false\n  AND a.datetime >= NOW() + INTERVAL '2 hours 30 minutes'\n  AND a.datetime <= NOW() + INTERVAL '3 hours 30 minutes'\nORDER BY a.datetime ASC\nLIMIT 100;",
        "options": {}
      },
