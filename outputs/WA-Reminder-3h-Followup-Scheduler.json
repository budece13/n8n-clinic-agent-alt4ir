    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const appt = $json;\nconst dt = new Date(appt.datetime);\nconst tz = appt.timezone || 'Europe/Madrid';\nconst hora = dt.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit', timeZone: tz });\nconst nombre = appt.patient_name || '';\nconst horasAntes = Math.round((dt.getTime() - Date.now()) / 3600000);\n\n// Politica de cancelacion\nconst policy = appt.cancellation_policy_hours || 24;\nconst horasRestantes = (dt.getTime() - Date.now()) / 3600000;\nconst canCancelFree = horasRestantes >= policy;\n\nconst cancelNote = canCancelFree\n  ? 'Responde *NO* si necesitas cancelar'\n  : `Ten en cuenta que las cancelaciones con menos de ${policy}h pueden tener cargo segun nuestra politica`;\n\nconst message_text = `Recordatorio importante${nombre ? ', ' + nombre : ''}\\n\\nTu cita en *${appt.clinic_name}* es *hoy a las ${hora}* (en aproximadamente ${horasAntes} horas).\\n\\nServicio: ${appt.service}\\n\\nNo hemos recibido tu confirmacion. Sigues viniendo?\\n\\nResponde *SI* para confirmar\\n${cancelNote}\\nResponde *CAMBIAR* si necesitas otra fecha\\n\\nSi no puedes asistir, por favor avisanos para liberar el horario.`;\n\n// Flag para alerta interna a clinica si < 2h\nconst needs_clinic_alert = horasRestantes < 2;\n\nreturn { json: { ...appt, message_text, needs_clinic_alert, hours_remaining: horasRestantes } };"
      },
