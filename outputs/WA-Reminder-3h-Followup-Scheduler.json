        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{ $('Formatear Mensaje Urgente 3h').first().json.patient_phone }}\",\n  \"type\": \"text\",\n  \"text\": { \"body\": {{ JSON.stringify($('Formatear Mensaje Urgente 3h').first().json.message_text) }} }\n}",
        "options": {
          "timeout": 10000
